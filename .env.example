# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it is gitignored.

# Server-side: Vertex AI / Gemini key used by /api/chat and tools.
# Restrict by API + caller in the Google Cloud console.
VERTEX_API_KEY=

# Firebase client SDK config (NEXT_PUBLIC_* is exposed to the browser by design).
# Security relies on Firestore rules + App Check, not on hiding these values.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
